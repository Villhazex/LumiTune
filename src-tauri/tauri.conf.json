{
  "build": {
    "beforeDevCommand": "node server.js",
    "devPath": "http://localhost:3001",
    "beforeBuildCommand": "node prep-build.js",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LumiTune",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "dialog": { "all": true },
      "window": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.lumitune.app",
      "resources": [
        "resources/yt-dlp.exe"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "decorations": false,
        "fullscreen": false,
        "resizable": true,
        "title": "LumiTune",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ]
  }
}
