{
  "build": {
    "beforeDevCommand": "node server.js",
    "devPath": "http://localhost:3001",
    "beforeBuildCommand": "node prep-build.js",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LumiTune",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "dialog": { "all": true },
      "window": { "all": true },
      "protocol": { "asset": true, "assetScope": ["**"] }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.lumitune.app",
      "resources": [
        "resources/yt-dlp.exe",
        "resources/fpcalc.exe"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://cdn.jsdelivr.net https://lrclib.net asset:; media-src 'self' blob: asset:; img-src 'self' data: https: blob: asset:; font-src 'self' data: https://fonts.gstatic.com"
    },
    "windows": [
      {
        "decorations": false,
        "fileDropEnabled": false,
        "fullscreen": false,
        "resizable": true,
        "title": "LumiTune",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ]
  }
}
